# Browser-safe publishable key (pk_*) from the MonetizeKit dashboard (Settings → API keys).
NEXT_PUBLIC_MONETIZEKIT_PUBLISHABLE_KEY=pk_live_xxx
# Your MonetizeKit API origin (serves the public REST API at /api/v1).
NEXT_PUBLIC_MONETIZEKIT_BASE_URL=https://app.monetizekit.app
# Optional: a customer id to resolve entitlements for the gated feature.
NEXT_PUBLIC_MONETIZEKIT_CUSTOMER_ID=
